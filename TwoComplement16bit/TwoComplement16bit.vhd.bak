library ieee;
use ieee.std_logic_1164.all;

entity TwoComplement16bit is port(
	R : in std_logic_vector (15 downto 0);
	N : out Std_logic_vector (15 downto 0);
	Overflow : out std_logic);
end TwoComplement16bit;

architecture StructTwoComplement16bit of TwoComplement16bit is
component MyNot is port(
	A : in std_logic;
	Q : out std_logic);
end component 

component MyFullAdder16bit is port(
	A : in std_logic_vector (15 downto 0);
	B : in std_logic_vector (15 downto 0);
	Cin : in std_logic;
	Sum : out std_logic_vector (15 downto 0);
	Cout : out std_logic);
end component;

signal C : std_logic_vector (15 downto 1);

B <= (others => '0')
Cin <= '1'
v0 : MyNot port map(R(0), A(0));
v1 : MyNot port map(R(1), A(1));
v2 : MyNot port map(R(2), A(2));
v3 : MyNot port map(R(3), A(3));
v4 : MyNot port map(R(4), A(4));
v5 : MyNot port map(R(5), A(5));
v6 : MyNot port map(R(6), A(6));
v7 : MyNot port map(R(7), A(7));
v8 : MyNot port map(R(8), A(8));
v9 : MyNot port map(R(9), A(9));
v10 : MyNot port map(R(10), A(10));
v11 : MyNot port map(R(11), A(11));
v12 : MyNot port map(R(12), A(12));
v13 : MyNot port map(R(13), A(13));
v14 : MyNot port map(R(14), A(14));
v15 : MyNot port map(R(15), A(15);
v16 : MyFullAdder16bit(A, B, Cin, R, Overflow)
